# EnergyOracle Environment Configuration
# Copy this file to .env and modify as needed.

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Logging
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Model directory (relative to backend/)
MODELS_DIR=../models

# Data directory (relative to backend/)
DATA_DIR=../data
